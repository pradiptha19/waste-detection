# ========================================
# WASTE DETECTION SYSTEM - CONFIGURATION
# Optimized for Maximum Detection + Auto GPS
# ========================================

# ========== CAMERA SETTINGS - AUTO GPS ENABLED ==========
PHONE_IP=192.168.0.103
CAMERA_NAME=Mobile Detection Camera

# ⚠️ COMMENT OUT THESE 3 LINES FOR AUTO GPS DETECTION:
# CAMERA_LOCATION=RNS Institute of Technology, Channasandra, Bangalore
# CAMERA_LATITUDE=12.90111
# CAMERA_LONGITUDE=77.51806

# 💡 OR keep them as fallback (system will try IP first, then use these if failed)
CAMERA_LOCATION=RNS Institute of Technology, Channasandra, Bangalore
CAMERA_LATITUDE=12.90111
CAMERA_LONGITUDE=77.51806

USE_PHONE_GPS=false

# ========== MODEL SETTINGS - ULTRA-AGGRESSIVE ==========
MODEL_PATH=models/best.pt
CONFIDENCE_THRESHOLD=0.20
IOU_THRESHOLD=0.35
MIN_BOX_AREA=600

# ========== ALERT SETTINGS - IMMEDIATE ==========
ALERT_THRESHOLD=1
ALERT_COOLDOWN=2
SAVE_DETECTIONS=true

# ========== EMAIL ALERTS - ENABLED ==========
ENABLE_EMAIL=true
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
EMAIL_FROM=wastedetection.project@gmail.com
EMAIL_PASSWORD=tlxdezanmyblbodr
ALERT_EMAIL_TO=pradiptham24@gmail.com

# ========== DATABASE ==========
DATABASE_URL=sqlite:///./data/waste_detection.db

# ========== ADVANCED DETECTION SETTINGS ==========
IMAGE_SIZE=1600
USE_MULTISCALE=true
USE_WATER_ENHANCEMENT=true
USE_ADAPTIVE_THRESHOLD=true

# Tracking settings
SMOOTHING_WINDOW=30
STABILITY_FRAMES=10
STABILITY_THRESHOLD=0.65

# Detection quality
MIN_CONFIDENCE=0.20
MAX_DETECTIONS=20
